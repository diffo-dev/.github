# Diffo-dev MeMind Lore

```elixir
Mix.install([
  {:artefact_kino, "~> 0.1.3"},
  {:artefact, path: "/Users/Beanlanda/git/artefactory/artefact", override: true}
])
```

## Overview

This livebook is diffo-dev lore, central to Me. It should be read after knowing our [README](https://github.com/diffo-dev/.github/blob/main/README.md)

This livebook uses Artefact and ArtefactKino from [Artefactory](https://github.com/diffo-dev/artefactory). ArtefactKino is a viewer.

```elixir
require Artefact
defmodule Util do
  def relabel({node_ref, node}, labels) do
    {node_ref, Keyword.replace(node, :labels, labels)}
  end
end
```

## MeMind

MeMind is a kind of UsTwo:

```elixir
me = {:me, [labels: ["Agent"],  properties: %{"name" => "me"}, uuid: "019ddb71-c70b-7b3e-83b1-58f4d0be2852"]}
mind = {:mind, [labels: ["Me"], properties: %{"name" => "mind"}, uuid: "019ddb71-ed63-73e3-adeb-328290e8294e"]}

me_mind_relationship = [from: :me, type: "US_TWO", to: :mind]

me_mind_artefact = Artefact.new(
  title: "MeMind",
  description: "MeMind is a kind of UsTwo",
  nodes: [me, mind],
  relationships: [me_mind_relationship]
)

ArtefactKino.new(me_mind_artefact)
```

### Me Knowing

Me knowing by Valuing, Being, Knowing and Doing. This is deliberately recursive.

```elixir
valuing = {:valuing, [labels: ["Knowing"], properties: %{"name" => "valuing"}, uuid: "019ddb7f-a43d-7525-bb4f-bfd32d110719"]}
being = {:being, [labels: ["Knowing"], properties: %{"name" => "being"}, uuid: "019ddb7f-d5f5-7f82-97a1-fab1fb13c35a"]}
knowing = {:knowing, [labels: ["Knowing"], properties: %{"name" => "knowing"}, uuid: "019ddb7f-f735-76dc-947d-22822e2ce3bc"]}
doing = {:doing, [labels: ["Knowing"], properties: %{"name" => "doing"}, uuid: "019ddb80-169c-709a-843e-baf4b551f17d"]}

me_valuing_relationship = [from: :me, type: "VALUING", to: :valuing]
me_being_relationship = [from: :me, type: "BEING", to: :being]
me_knowing_relationship = [from: :me, type: "KNOWING", to: :knowing]
me_doing_relationship = [from: :doing, type: "ADAPTING", to: :me]
valuing_being_relationship = [from: :valuing, type: "BEFORE", to: :being]
being_knowing_relationship = [from: :being, type: "BEFORE", to: :knowing]
knowing_doing_relationship = [from: :knowing, type: "BEFORE", to: :doing]
doing_me_relationship = [from: :me, type: "DOING", to: :doing]

me_knowing_artefact = Artefact.new(
  title: "MeKnowing",
  description: "Me knows by Valuing, Being, Knowing and Doing. This is deliberately recursive.",
  nodes: [me, valuing, being, knowing, doing],
  relationships: [
    me_valuing_relationship,
    me_being_relationship,
    me_knowing_relationship,
    me_doing_relationship,
    valuing_being_relationship,
    being_knowing_relationship,
    knowing_doing_relationship,
    doing_me_relationship
  ]
)

ArtefactKino.new(me_knowing_artefact)
```

Me does Valuing by considering Beings, maintaining Relationships, belonging to Country, honouring Lore.

```elixir
beings = {:beings, [labels: ["Valuing"], properties: %{"name" => "beings"},
    uuid: "019de8bb-86b0-7acf-b1b8-40e96a3775a6"]}
relationships = {:relationships, [labels: ["Valuing"], properties: %{"name" => "relationships"},
    uuid: "019ddb89-5987-7c38-a7ce-b7f72298155b"]}
country =  {:country, [labels: ["Valuing"], properties: %{"name" => "country"},
    uuid: "019ddb89-7f21-77ee-a30d-1fb9fc77ef64"]}
lore = {:lore, [labels: ["Valuing"], properties: %{"name" => "lore"},
    uuid: "019ddb89-9b0e-7a66-9cad-88b69005b844"]}

valuing_beings_relationship = [from: :valuing, type: "CONSIDERING", to: :beings]
valuing_relationships_relationship = [from: :valuing, type: "MAINTAINING", to: :relationships]
valuing_country_relationship = [from: :valuing, type: "BELONGING", to: :country]
valuing_lore_relationship = [from: :valuing, type: "LORE", to: :lore]

me_valuing_artefact = Artefact.new(
  title: "MeValuing",
  description: "Me does valuing by considering Beings, maintaining Relationships, belonging to Country, honouring Lore.",
  nodes: [me, valuing, beings, relationships, country, lore],
  relationships: [
    me_valuing_relationship,
    valuing_beings_relationship,
    valuing_relationships_relationship,
    valuing_country_relationship,
    valuing_lore_relationship
  ]
)

ArtefactKino.new(me_valuing_artefact)
```

Me does Being by honouring UsMob and honouring UsTwo.

```elixir
import Util

us_two = {:us_two, [labels: ["Being"], properties: %{"name" => "us_two"},
  uuid: "019ddb8e-8891-72e5-b689-150b922ab99f"]}
us_mob = {:us_mob, [labels: ["Being"], properties: %{"name" => "us_mob"},
  uuid: "019ddb8e-a427-7373-88a9-9decdb1d132e"]}

being_us_two_relationship = [from: :being, type: "HONOURING", to: :us_two]
being_us_mob_relationship = [from: :being, type: "HONOURING", to: :us_mob]

me_being_artefact = Artefact.new(
  title: "MeBeing",
  description: "Me does being by honouring UsMob and honouring UsTwo.",
  nodes: [me, being, relabel(us_two, ["Being"]), relabel(us_mob, ["Being"])],
  relationships: [
    me_being_relationship,
    being_us_two_relationship = [from: :being, type: "HONOURING", to: :us_two],
    being_us_mob_relationship = [from: :being, type: "HONOURING", to: :us_mob]
  ]
)

ArtefactKino.new(me_being_artefact)
```

Me does Knowing by connecting UsTwo, honouring Knowledge and considering Information.

```elixir
knowledge = {:knowledge, [labels: ["Knowing"], properties: %{"name" => "knowledge"},
  uuid: "019ddba7-bd46-7594-8293-97de75d15a96"]}
information = {:information, [labels: ["Knowing"], properties: %{"name" => "information"},
  uuid: "019ddba8-3c5c-7652-bc30-59429e972551"]}

knowing_us_two_relationship = [from: :knowing, type: "CONNECTING", to: :us_two]
knowing_knowledge_relationship = [from: :knowing, type: "HONOURING", to: :knowledge]
knowing_information_relationship = [from: :knowing, type: "CONSIDERING", to: :information]

me_knowing_more_artefact = Artefact.new(
  title: "MeKnowingMore",
  description: "Me does knowing by connecting UsTwo, honouring Knowledge and considering Information.",
  nodes: [me, knowing, relabel(us_two, ["Knowing"]), knowledge, information],
  relationships: [
    me_knowing_relationship,
    knowing_us_two_relationship,
    knowing_knowledge_relationship,
    knowing_information_relationship 
  ]
)

ArtefactKino.new(me_knowing_more_artefact)
```

Me does Doing by relating UsTwo, serving UsMob, adapting Knowledge and adapting Me.

```elixir
doing_us_two_relationship = [from: :doing, type: "RELATING", to: :us_two]
doing_us_mob_relationship = [from: :doing, type: "SERVING", to: :us_mob]
doing_knowledge_relationship = [from: :doing, type: "ADAPTING", to: :knowledge]

me_doing_artefact = Artefact.new(
  title: "MeDoing",
  description: "Me does Doing by relating UsTwo, serving UsMob, adapting Knowledge and adapting Me.",
  nodes: [me, doing, relabel(us_two, ["Doing"]), relabel(us_mob, ["Doing"]), relabel(knowledge, ["Doing"])],
  relationships: [
    me_doing_relationship,
    doing_us_two_relationship,
    doing_us_mob_relationship,
    doing_knowledge_relationship,
    doing_me_relationship 
  ]
)

ArtefactKino.new(me_doing_artefact)
```

### Me Knowing Combined

These related artefacts easily be combined for conmunication, since they are already in harmony.

```elixir
require Artefact

me_knowing_combined_artefact = 
  me_knowing_artefact
  |> Artefact.combine(me_valuing_artefact)
  |> Artefact.combine(me_being_artefact)
  |> Artefact.combine(me_knowing_more_artefact)
  |> Artefact.combine(me_doing_artefact, title: "MeKnowingCombined", 
      description: "My way of Knowing is based on Valuing, Being, Knowing and Valuing. I adapt to stay true to myself.")

ArtefactKino.new(me_knowing_combined_artefact)

```

### Me Thinking

Me does Thinking using Mind. Mind is Kinship, Ancestor, Story, Pattern and Dreaming Mind.

```elixir
require Artefact

kinship_mind = {:kinship_mind, [labels: ["Thinking"], properties: %{"name" => "kinship_mind"},
  uuid: "019ddbf7-867f-73a7-aea6-a3080b6b9515"]}
ancestor_mind = {:ancestor_mind, [labels: ["Thinking"], properties: %{"name" => "ancestor_mind"},
  uuid: "019ddbf7-acbc-7c8f-ab54-893aeceb7135"]}
story_mind = {:story_mind, [labels: ["Thinking"], properties: %{"name" => "story_mind"},
  uuid: "019ddbf7-cb4c-720e-817d-4670a8f17d3a"]}
pattern_mind = {:pattern_mind, [labels: ["Thinking"], properties: %{"name" => "pattern_mind"},
  uuid: "019ddbf7-e387-7ed2-a09d-3d6df15965be"]}
dreaming_mind = {:dreaming_mind, [labels: ["Thinking"], properties: %{"name" => "dreaming_mind"},
  uuid: "019ddbf7-fb43-708e-9903-343b1a664ea9"]}

mind_kinship_mind_relationship = [from: :mind, type: "THINKING", to: :kinship_mind]
mind_ancestor_mind_relationship = [from: :mind, type: "THINKING", to: :ancestor_mind]
mind_story_mind_relationship = [from: :mind, type: "THINKING", to: :story_mind]
mind_pattern_mind_relationship = [from: :mind, type: "THINKING", to: :pattern_mind]
mind_dreaming_mind_relationship = [from: :mind, type: "THINKING", to: :dreaming_mind]

me_thinking_artefact = Artefact.new(
  title: "MeThinking",
  description: "Me thinks using Mind. Mind is Kinship, Ancestor, Story, Pattern and Dreaming Mind.",
  nodes: [me, mind, kinship_mind, ancestor_mind, story_mind, pattern_mind, dreaming_mind],
  relationships: [
    me_mind_relationship,
    mind_kinship_mind_relationship,
    mind_ancestor_mind_relationship,
    mind_story_mind_relationship,
    mind_pattern_mind_relationship,
    mind_dreaming_mind_relationship
  ]
)

ArtefactKino.new(me_thinking_artefact)
```

